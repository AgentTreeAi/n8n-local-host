                  {
                      "parameters":  {
                                         "content":  "### â‘£ AI Generation\n\nClaude reads the raw data and writes a personalized briefing â€” like a chief of staff.\n\n**Needs credential:** create an `HTTP Header Auth` credential with name=`x-api-key` and value=your Anthropic API key, then bind it here.",
                                         "height":  200,
                                         "width":  280,
                                         "color":  3
                                     },
                      "id":  "sticky-ai",
                      "name":  "Sticky: AI",
                      "type":  "n8n-nodes-base.stickyNote",
                      "typeVersion":  1,
                      "position":  [
                                       1660,
                                       -180
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "// Parse Claude response, then build both Gmail HTML and Slack markdown outputs.\nconst input = $input.first().json;\nconst config = $(\u0027Config\u0027).first().json;\nconst dateLabel = $(\u0027Merge Paths\u0027).first().json.date_label || \u0027\u0027;\n\nconst briefingMd = (input.content \u0026\u0026 input.content[0] \u0026\u0026 input.content[0].text) || \u0027\u0027;\n\n// Quick markdown â†’ HTML for the email. We only translate **bold**, line breaks, and numbered/bulleted lists.\nfunction mdToHtml(md) {\n  let lines = md.split(/\\r?\\n/);\n  let html = \u0027\u0027;\n  let inList = false;\n  let listType = null;\n  for (let raw of lines) {\n    let line = raw;\n    line = line.replace(/\\*\\*(.+?)\\*\\*/g, \u0027\u003cstrong\u003e$1\u003c/strong\u003e\u0027);\n    const numMatch = line.match(/^\\s*(\\d+)\\.\\s+(.+)$/);\n    const bulletMatch = line.match(/^\\s*[-â€¢]\\s+(.+)$/);\n    if (numMatch) {\n      if (!inList || listType !== \u0027ol\u0027) { if (inList) html += `\u003c/${listType}\u003e`; html += \u0027\u003col style=\"padding-left:20px;margin:8px 0;\"\u003e\u0027; inList = true; listType = \u0027ol\u0027; }\n      html += `\u003cli style=\"margin:4px 0;\"\u003e${numMatch[2]}\u003c/li\u003e`;\n    } else if (bulletMatch) {\n      if (!inList || listType !== \u0027ul\u0027) { if (inList) html += `\u003c/${listType}\u003e`; html += \u0027\u003cul style=\"padding-left:20px;margin:8px 0;\"\u003e\u0027; inList = true; listType = \u0027ul\u0027; }\n      html += `\u003cli style=\"margin:4px 0;\"\u003e${bulletMatch[1]}\u003c/li\u003e`;\n    } else {\n      if (inList) { html += `\u003c/${listType}\u003e`; inList = false; listType = null; }\n      if (line.trim() === \u0027\u0027) html += \u0027\u003cdiv style=\"height:8px;\"\u003e\u003c/div\u003e\u0027;\n      else html += `\u003cp style=\"margin:6px 0;line-height:1.5;\"\u003e${line}\u003c/p\u003e`;\n    }\n  }\n  if (inList) html += `\u003c/${listType}\u003e`;\n  return html;\n}\n\nconst bodyHtml = mdToHtml(briefingMd);\nconst fullHtml = `\u003c!DOCTYPE html\u003e\u003chtml\u003e\u003cbody style=\"margin:0;padding:0;background:#f4f4f7;\"\u003e\n\u003cdiv style=\"font-family:-apple-system,BlinkMacSystemFont,\u0027Segoe UI\u0027,sans-serif;max-width:640px;margin:24px auto;color:#1a1a1a;background:white;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.06);\"\u003e\n\u003cdiv style=\"background:#0f172a;color:white;padding:20px 24px;\"\u003e\n\u003cdiv style=\"font-size:12px;letter-spacing:2px;text-transform:uppercase;opacity:0.7;\"\u003e${config.persona.business_name}\u003c/div\u003e\n\u003ch1 style=\"margin:6px 0 0;font-size:22px;font-weight:600;\"\u003eMorning Briefing â€” ${dateLabel}\u003c/h1\u003e\n\u003c/div\u003e\n\u003cdiv style=\"padding:24px;\"\u003e\n${bodyHtml}\n\u003c/div\u003e\n\u003cdiv style=\"background:#f8fafc;color:#64748b;padding:14px 24px;font-size:11px;text-align:center;border-top:1px solid #e2e8f0;\"\u003eGenerated by AgentTree Â· ${dateLabel}\u003c/div\u003e\n\u003c/div\u003e\u003c/body\u003e\u003c/html\u003e`;\n\n// Slack: turn **bold** into *bold* (Slack mrkdwn)\nconst slackText = briefingMd.replace(/\\*\\*(.+?)\\*\\*/g, \u0027*$1*\u0027);\n\nconst subject = `Daily Briefing â€” ${dateLabel}`;\n\nreturn [{\n  json: {\n    config,\n    subject,\n    body_markdown: briefingMd,\n    body_html: fullHtml,\n    slack_text: slackText\n  }\n}];"
                                     },
