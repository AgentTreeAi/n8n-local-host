                      "id":  "sticky-live",
                      "name":  "Sticky: Live Path",
                      "type":  "n8n-nodes-base.stickyNote",
                      "typeVersion":  1,
                      "position":  [
                                       700,
                                       760
                                   ]
                  },
                  {
                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "language":  "javaScript",
                                         "jsCode":  "// Normalize the three live API outputs into the same shape as Seed Demo Data.\n// We reach back to each fetch node by name so we don\u0027t depend on merge order.\n\nconst config = $(\u0027Config\u0027).first().json;\nconst now = new Date();\nconst months = [\u0027Jan\u0027,\u0027Feb\u0027,\u0027Mar\u0027,\u0027Apr\u0027,\u0027May\u0027,\u0027Jun\u0027,\u0027Jul\u0027,\u0027Aug\u0027,\u0027Sep\u0027,\u0027Oct\u0027,\u0027Nov\u0027,\u0027Dec\u0027];\nconst dayNames = [\u0027Sunday\u0027,\u0027Monday\u0027,\u0027Tuesday\u0027,\u0027Wednesday\u0027,\u0027Thursday\u0027,\u0027Friday\u0027,\u0027Saturday\u0027];\nconst dateLabel = `${dayNames[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()}`;\n\n// Todoist\nconst todoistItems = $(\u0027Todoist: Today + Overdue\u0027).all().map(i =\u003e i.json);\nconst priorityMap = { 4: \u0027P1\u0027, 3: \u0027P2\u0027, 2: \u0027P3\u0027, 1: \u0027P4\u0027 };\nconst overdue = [];\nconst today = [];\nfor (const t of todoistItems) {\n  const dueDate = t.due ? new Date(t.due.date) : null;\n  const isOverdue = dueDate \u0026\u0026 dueDate \u003c new Date(now.toDateString());\n  const entry = {\n    content: t.content,\n    priority: priorityMap[t.priority] || \u0027P4\u0027,\n    due_string: t.due ? t.due.string : \u0027\u0027\n  };\n  if (isOverdue) {\n    entry.days_overdue = Math.floor((now - dueDate) / 86400000);\n    overdue.push(entry);\n  } else {\n    today.push(entry);\n  }\n}\n\n// Calendar\nlet calendarEvents = [];\ntry {\n  const events = $(\u0027Calendar: Today\\\u0027s Events\u0027).all().map(i =\u003e i.json);\n  calendarEvents = events.map(e =\u003e {\n    const startISO = e.start \u0026\u0026 (e.start.dateTime || e.start.date);\n    const startD = startISO ? new Date(startISO) : null;\n    const time = startD ? startD.toLocaleTimeString(\u0027en-US\u0027, { hour: \u0027numeric\u0027, minute: \u00272-digit\u0027 }) : \u0027All day\u0027;\n    return { time, summary: e.summary || \u0027(no title)\u0027 };\n  });\n} catch (e) {\n  calendarEvents = [];\n}\n\n// Gmail\nlet priorityEmails = [];\ntry {\n  const msgs = $(\u0027Gmail: Priority Unread\u0027).all().map(i =\u003e i.json);\n  priorityEmails = msgs.slice(0, 5).map(m =\u003e {\n    const fromHeader = (m.payload \u0026\u0026 m.payload.headers || []).find(h =\u003e h.name === \u0027From\u0027);\n    const subjHeader = (m.payload \u0026\u0026 m.payload.headers || []).find(h =\u003e h.name === \u0027Subject\u0027);\n    return {\n      from: fromHeader ? fromHeader.value : (m.from || \u0027\u0027),\n      subject: subjHeader ? subjHeader.value : (m.subject || m.snippet || \u0027\u0027),\n      received: m.internalDate ? new Date(parseInt(m.internalDate)).toLocaleTimeString(\u0027en-US\u0027, { hour: \u0027numeric\u0027, minute: \u00272-digit\u0027 }) : \u0027\u0027\n    };\n  });\n} catch (e) {\n  priorityEmails = [];\n}\n\nreturn [{\n  json: {\n    config,\n    date_label: dateLabel,\n    overdue_tasks: overdue,\n    today_tasks: today,\n    calendar_events: calendarEvents,\n    priority_emails: priorityEmails,\n    pipeline: null  // live pipeline data left to a future CRM integration\n  }\n}];"
                                     },
