# === n8n Configuration ===
N8N_HOST=n8n.yourdomain.com
GENERIC_TIMEZONE=America/Los_Angeles
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_PASTE_TUNNEL_TOKEN

# === Frontend / Vercel serverless proxy ===
# Set these as Environment Variables in the Vercel project (NOT committed).
# Used locally by the Vite dev proxy (vite.config.js reads N8N_URL/N8N_API_KEY).
N8N_URL=https://n8n.workflowsolution.org
N8N_API_KEY=CHANGE_ME_N8N_PUBLIC_API_KEY
# Shared password that gates the public web app. Anyone with the URL must enter
# this before the proxy will use N8N_API_KEY. Make it long and random.
APP_PASSWORD=CHANGE_ME_LONG_RANDOM_APP_PASSWORD
