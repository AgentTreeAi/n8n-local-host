{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/proxy?endpoint=/api/v1/:path*"
    },
    {
      "source": "/webhook/:path*",
      "destination": "https://n8n.workflowsolution.org/webhook/:path*"
    },
    {
      "source": "/webhook-test/:path*",
      "destination": "https://n8n.workflowsolution.org/webhook-test/:path*"
    }
  ]
}
